{
  "theme": "TouchGrass-Neobrutalism",
  "colors": {
    "primary": "#39FF14", 
    "secondary": "#00BFFF", 
    "tertiary": "#8B4513", 
    "background": "#FFFFFF",
    "surface": "#EAEAEA",
    "text": "#000000",
    "border": "#000000",
    "alert": "#FF003C",
    "warning": "#FFEA00"
  },
  "typography": {
    "fonts": {
      "heading": "'Archivo Black', 'Impact', sans-serif",
      "body": "'Space Mono', 'Courier New', monospace"
    },
    "sizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.25rem",
      "xl": "1.5rem",
      "xxl": "2.5rem",
      "brainrot": "4rem" 
    },
    "weights": {
      "regular": "400",
      "bold": "700",
      "black": "900"
    }
  },
  "borders": {
    "widths": {
      "thin": "2px",
      "thick": "4px",
      "massive": "8px"
    },
    "radius": {
      "none": "0px",
      "sm": "4px",
      "round": "50%" 
    }
  },
  "shadows": {
    "neobrutal": {
      "sm": "2px 2px 0px 0px #000000",
      "md": "4px 4px 0px 0px #000000",
      "lg": "8px 8px 0px 0px #000000",
      "pressed": "0px 0px 0px 0px #000000" 
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "bentoGap": "16px"
  },
  "animation": {
    "timing": {
      "instant": "0ms",
      "snappy": "100ms",
      "shake": "300ms"
    },
    "curves": {
      "bounce": "cubic-bezier(0.175, 0.885, 0.32, 1.275)"
    }
  }
}